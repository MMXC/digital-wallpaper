# Slack API 凭证
# 1. 创建 Slack App: https://api.slack.com/apps
# 2. 启用 Socket Mode
# 3. 订阅 bot 事件: message.channels
# 4. 安装到工作区

# 从 Slack API 获取
SLACK_SIGNING_SECRET=your_signing_secret_here
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# 频道 ID
SLACK_CHANNEL_ID=C0AK3SLCJ6A

# 监听配置
# 只监听指定用户（用逗号分隔用户ID），null=监听全部
# SLACK_LISTEN_USERS=U0AGB6GCUUA,U0XXXXXXX

# 消息关键词过滤（用逗号分隔），null=处理所有消息
# SLACK_FILTER_KEYWORDS=任务,agent,状态
